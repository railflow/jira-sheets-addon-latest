rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Individual licenses - only accessible by Cloud Functions
    match /licenses/{email} {
      allow read, write: if false;
    }
    
    // Domain-wide licenses (company purchases) - only accessible by Cloud Functions
    match /domain_licenses/{domain} {
      allow read, write: if false;
    }
    
    // If you need authenticated user access in the future
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
